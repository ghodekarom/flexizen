# ========================================
# FlexiZen Root Git Ignore
# ========================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
package.json
package-lock.json

# IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Java / Maven (Root should not have build artifacts)
target/
*.class
*.war
*.ear
*.jar

# FlexiZen Specific
backend/target/
frontend/node_modules/
frontend/dist/
frontend/.env
